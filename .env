# .env — copy this to the project root before running docker compose
# All values here are development defaults; override in production.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpass
POSTGRES_DB=taskqueue
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL=2.0
WORKER_MAX_RETRIES=3
WORKER_COUNT=2

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
